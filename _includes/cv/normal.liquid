{% comment %}
  Unified normal entry renderer for RenderCV NormalEntry sections
  Handles name, date, location, summary, and highlights.
{% endcomment %}

<ul class="card-text font-weight-light list-group list-group-flush">
  {% for entry in entries %}
    {% capture entry_date %}
      {% if entry.date %}
        {{ entry.date }}
      {% elsif entry.start_date %}
        {{ entry.start_date | split: '-' | first }} - {{ entry.end_date | default: 'present' | split: '-' | first }}
      {% endif %}
    {% endcapture %}
    {% assign entry_date = entry_date | strip %}
    {% assign use_date_column = false %}
    {% if entry_date != '' and entry_date.size <= 9 %}
      {% assign use_date_column = true %}
    {% endif %}
    <li class="list-group-item">
      <div class="row">
        {% if use_date_column %}
          <div class="col-xs-2 col-sm-2 col-md-2 text-center date-column">
            <table class="table-cv">
              <tbody>
                <tr>
                  <td>
                    <span class="badge font-weight-bold danger-color-dark text-uppercase align-middle" style="min-width: 75px">
                      {{ entry_date }}
                    </span>
                  </td>
                </tr>
                {% if entry.location %}
                  <tr>
                    <td>
                      <p class="location">
                        <i class="fa-solid fa-location-dot iconlocation"></i>
                        {{ entry.location }}
                      </p>
                    </td>
                  </tr>
                {% endif %}
              </tbody>
            </table>
          </div>
          <div class="col-xs-10 col-sm-10 col-md-10 mt-2 mt-md-0">
        {% else %}
          <div class="col-xs-12 col-sm-12 col-md-12">
        {% endif %}
            {% if entry.url %}
              <h6 class="title font-weight-bold ml-1 ml-md-4">
                <a href="{{ entry.url }}" target="_blank" rel="noopener noreferrer">{{ entry.name }}</a>
              </h6>
            {% else %}
              <h6 class="title font-weight-bold ml-1 ml-md-4">{{ entry.name }}</h6>
            {% endif %}

            {% if entry_date != '' and use_date_column == false %}
              <p class="ml-1 ml-md-4 mb-1 text-muted">
                <small>{{ entry_date }}</small>
              </p>
            {% endif %}

            {% if entry.summary %}
              <p class="ml-1 ml-md-4 mb-2">{{ entry.summary | markdownify | remove: '<p>' | remove: '</p>' }}</p>
            {% endif %}

            {% if entry.highlights %}
              <ul class="items mb-0">
                {% for item in entry.highlights %}
                  <li>
                    <span class="item">{{ item | markdownify | remove: '<p>' | remove: '</p>' }}</span>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
      </div>
    </li>
  {% endfor %}
</ul>
