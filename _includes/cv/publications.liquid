{% comment %}
  Unified publications entry renderer for both formats
{% endcomment %}

<ul class="card-text font-weight-light list-group list-group-flush">
  {% for entry in entries %}
    <li class="list-group-item">
      <div class="row">
        {% capture pub_date %}
          {% if entry.releaseDate %}{{ entry.releaseDate }}{% elsif entry.date %}{{ entry.date }}{% endif %}
        {% endcapture %}

        {% if pub_date != '' %}
          <div class="col-xs-2 col-sm-2 col-md-2 text-center">
            <table class="table-cv">
              <tbody>
                <tr>
                  <td>
                    <span class="badge font-weight-bold danger-color-dark text-uppercase align-middle" style="min-width: 75px">
                      {{- pub_date | split: '-' | slice: 0, 1 | join: '' -}}
                    </span>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
          <div class="col-xs-10 col-sm-10 col-md-10 mt-2 mt-md-0">
            {% if entry.title %}
              <h6 class="title font-weight-bold ml-1 ml-md-4">{{ entry.title }}</h6>
            {% endif %}

            {% assign authors = entry.authors | default: entry.author %}
            {% if authors %}
              <p class="ml-1 ml-md-4 mb-1">
                {% for author in authors %}
                  {{ author | markdownify | remove: '<p>' | remove: '</p>' }}{% unless forloop.last %}{% if forloop.rindex == 2 %} and {% else %}, {% endif %}{% endunless %}
                {% endfor %}
              </p>
            {% endif %}

            {% if entry.journal or entry.publisher %}
              <p class="ml-1 ml-md-4 mb-1">
                <em>{{ entry.journal | default: entry.publisher }}</em>
              </p>
            {% endif %}

            {% if entry.summary %}
              <p class="ml-1 ml-md-4 mb-1">{{ entry.summary | markdownify | remove: '<p>' | remove: '</p>' }}</p>
            {% endif %}

            {% if entry.url or entry.code_url %}
              <p class="ml-1 ml-md-4 mb-0">
                {% if entry.url %}
                  <a href="{{ entry.url }}" target="_blank" rel="noopener noreferrer">Paper</a>
                {% endif %}
                {% if entry.url and entry.code_url %}
                  <span> · </span>
                {% endif %}
                {% if entry.code_url %}
                  <a href="{{ entry.code_url }}" target="_blank" rel="noopener noreferrer">Code</a>
                {% endif %}
              </p>
            {% endif %}
          </div>
        {% else %}
          <div class="col-xs-12 col-sm-12 col-md-12">
            {% if entry.title %}
              <h6 class="title font-weight-bold ml-1 ml-md-4">{{ entry.title }}</h6>
            {% endif %}

            {% assign authors = entry.authors | default: entry.author %}
            {% if authors %}
              <p class="ml-1 ml-md-4 mb-1">
                {% for author in authors %}
                  {{ author | markdownify | remove: '<p>' | remove: '</p>' }}{% unless forloop.last %}{% if forloop.rindex == 2 %} and {% else %}, {% endif %}{% endunless %}
                {% endfor %}
              </p>
            {% endif %}

            {% if entry.journal or entry.publisher %}
              <p class="ml-1 ml-md-4 mb-1">
                <em>{{ entry.journal | default: entry.publisher }}</em>
              </p>
            {% endif %}

            {% if entry.summary %}
              <p class="ml-1 ml-md-4 mb-1">{{ entry.summary | markdownify | remove: '<p>' | remove: '</p>' }}</p>
            {% endif %}

            {% if entry.url or entry.code_url %}
              <p class="ml-1 ml-md-4 mb-0">
                {% if entry.url %}
                  <a href="{{ entry.url }}" target="_blank" rel="noopener noreferrer">Paper</a>
                {% endif %}
                {% if entry.url and entry.code_url %}
                  <span> · </span>
                {% endif %}
                {% if entry.code_url %}
                  <a href="{{ entry.code_url }}" target="_blank" rel="noopener noreferrer">Code</a>
                {% endif %}
              </p>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </li>
  {% endfor %}
</ul>
